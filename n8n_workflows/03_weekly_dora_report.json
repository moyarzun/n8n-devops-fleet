{
  "name": "DevOps Fleet — Weekly DORA Report (Lunes 9am)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 9 * * 1" }]
        }
      },
      "id": "cron-weekly",
      "name": "Cron: Lunes 9am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DEVOPS_FLEET_API_URL }}/pipeline/metrics",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Content-Type", "value": "application/json" }]
        },
        "sendBody": true,
        "bodyContentType": "json",
        "jsonBody": "{\n  \"window_days\": 7,\n  \"report_type\": \"full\"\n}"
      },
      "id": "http-metrics",
      "name": "Fleet API: Generate Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "amount": 30,
        "unit": "seconds"
      },
      "id": "wait-report",
      "name": "Esperar 30s (pipeline async)",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.DEVOPS_FLEET_API_URL }}/metrics/dora"
      },
      "id": "http-dora-fetch",
      "name": "Fetch DORA snapshot",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 300]
    }
  ],
  "connections": {
    "Cron: Lunes 9am": {
      "main": [[{ "node": "Fleet API: Generate Report", "type": "main", "index": 0 }]]
    },
    "Fleet API: Generate Report": {
      "main": [[{ "node": "Esperar 30s (pipeline async)", "type": "main", "index": 0 }]]
    },
    "Esperar 30s (pipeline async)": {
      "main": [[{ "node": "Fetch DORA snapshot", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "tags": ["devops-fleet", "dora", "scheduled"]
}
